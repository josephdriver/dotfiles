font-family = "MesloLGS NF"
font-size = 14
theme = TokyoNight
cursor-style = block
cursor-blink = true
window-padding-x = 8
window-padding-y = 8
background-opacity = 0.95

# Tabs
keybind = cmd+t=new_tab
keybind = cmd+shift+[=previous_tab
keybind = cmd+shift+]=next_tab
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4

keybind = super+t=new_tab
keybind = super+shift+[=previous_tab
keybind = super+shift+]=next_tab
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4

# Splits
keybind = cmd+enter=new_split:right
keybind = cmd+shift+enter=new_split:down
keybind = cmd+option+h=goto_split:left
keybind = cmd+option+j=goto_split:down
keybind = cmd+option+k=goto_split:up
keybind = cmd+option+l=goto_split:right
keybind = cmd+shift+\\=toggle_split_zoom

keybind = super+enter=new_split:right
keybind = super+shift+enter=new_split:down
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:down
keybind = super+alt+k=goto_split:up
keybind = super+alt+l=goto_split:right
keybind = super+shift+\\=toggle_split_zoom
