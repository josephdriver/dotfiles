font-family = "MesloLGS NF"
font-size = 14
theme = TokyoNight
cursor-style = block
cursor-style-blink = true
window-padding-x = 8
window-padding-y = 8
background-opacity = 0.95

# Tabs
keybind = super+t=new_tab
keybind = ctrl+shift+arrow_left=previous_tab
keybind = ctrl+shift+arrow_right=next_tab
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4

# Splits
keybind = ctrl+shift+o=new_split:right
keybind = ctrl+shift+e=new_split:down
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:down
keybind = ctrl+alt+k=goto_split:up
keybind = ctrl+alt+l=goto_split:right
keybind = ctrl+shift+enter=toggle_split_zoom
